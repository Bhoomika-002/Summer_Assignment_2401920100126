class Solution {
public:
    vector<int> findAnagrams(string s, string p) {
        vector<int> result;
        if (s.size() < p.size())
            return result;
        vector<int> pCount(26, 0);
        vector<int> sCount(26, 0);
        for (char c : p)
            pCount[c - 'a']++;
        int k = p.size();
        for (int i = 0; i < s.size(); i++) {
            sCount[s[i] - 'a']++;
            // Remove character that goes out of the window
            if (i >= k) {
                sCount[s[i - k] - 'a']--;
            }
            // Compare frequency arrays
            if (sCount == pCount) {
                result.push_back(i - k + 1);
            }
        }
        return result;
    }
};
