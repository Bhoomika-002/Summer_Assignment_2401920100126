#include <iostream>
using namespace std;

// Question 1
class Test {
public:
    virtual int square(int) = 0;
};

class Arithmetic : public Test {
public:
    int square(int x) {
        return x * x;
    }
};

class ToTestInt {
public:
    void showSquare(int n) {
        Arithmetic a;
        cout << "Square = " << a.square(n) << endl;
    }
};

// Question 2
class Outer {
public:
    void display() {
        cout << "Outer class display" << endl;
    }

    class Inner {
    public:
        void display() {
            cout << "Inner class display" << endl;
        }
    };
};

// Question 3
class Point {
private:
    int x, y;

public:
    Point() {
        x = y = 0;
    }

    Point(int x, int y) {
        this->x = x;
        this->y = y;
    }

    void setX(int x) {
        this->x = x;
    }

    void setY(int y) {
        this->y = y;
    }

    void setXY(int x, int y) {
        this->x = x;
        this->y = y;
    }

    void display() {
        cout << "Point(" << x << "," << y << ")" << endl;
    }
};

// Question 4
class Box {
protected:
    double length, breadth;

public:
    Box(double l = 0, double b = 0) {
        length = l;
        breadth = b;
    }

    double area() {
        return length * breadth;
    }
};

class Box3D : public Box {
private:
    double height;

public:
    Box3D(double l, double b, double h) : Box(l, b) {
        height = h;
    }

    double volume() {
        return length * breadth * height;
    }
};

int main() {
    // Q1
    ToTestInt t;
    t.showSquare(6);

    // Q2
    Outer o;
    o.display();

    Outer::Inner i;
    i.display();

    // Q3
    Point p(10, 20);
    p.display();

    // Q4
    Box3D b(10, 5, 4);
    cout << "Volume = " << b.volume() << endl;

    return 0;
}
