class Solution {
public:
    vector<int> sortedSquares(vector<int>& nums) {
        int n =nums.size();
        vector<int>ans(n);
        int left_ptr=0,right_ptr=n-1;
        int index=n-1;
        while(left_ptr<=right_ptr){
            int leftsquare=nums[left_ptr]*nums[left_ptr];
            int rightsquare=nums[right_ptr]*nums[right_ptr];
            if(leftsquare>rightsquare){
                ans[index]=leftsquare;
                left_ptr++;
            } else{
                ans[index]=rightsquare;
                right_ptr--;
            }
            index--;

        }
        return ans;     
    }
};
