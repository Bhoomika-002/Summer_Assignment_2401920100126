class Solution {
public:
    vector<vector<int>> matrixReshape(vector<vector<int>>& mat, int r, int c) {
        int s = mat.size(),m = mat[0].size();
        if(s*m!=r*c) return mat;
        vector<vector<int>> ans(r,vector<int>(c));
        int row=0,col=0;
        for(int i=0;i<s;i++){
            for(int j=0;j<m;j++){
                ans[row][col++]= mat[i][j];
                if(col == c){
                    col=0;
                    row++;
                }
            }
        }
        return ans;
    }
};
